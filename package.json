{
  "name": "keybard",
  "version": "0.1.0",
  "description": "Web-based keyboard configurator for Svalboard keyboards",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "dev:python": "python devserver.py",
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "keyboard",
    "svalboard",
    "vial",
    "qmk",
    "configurator"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/w3c-web-usb": "^1.0.12",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.4",
    "mobx-devtools-mst": "^0.9.46",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.0"
  }
}
